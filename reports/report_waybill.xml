<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_report_waybill" model="ir.actions.report">
        <field name="name">Waybill</field>
        <field name="model">freight.trip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">freight_management_system.report_waybill_template</field>
        <field name="report_file">freight_management_system.report_waybill_template</field>
        <field name="binding_model_id" ref="model_freight_trip"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Report Template -->
    <template id="report_waybill_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="padding: 20px; font-family: 'Arial', sans-serif;">

                        <!-- Header -->
                        <div class="text-center mb-4" style="border-bottom: 2px solid #2c3e50; padding-bottom: 15px;">
                            <h1 style="color: #2c3e50; margin-bottom: 5px; font-size: 28px;">WAYBILL</h1>
                            <h3 style="color: #34495e; font-weight: normal;" t-field="doc.name"/>
                        </div>

                        <!-- Route & Carrier Info Row -->
                        <div style="display: flex; gap: 20px; margin-bottom: 25px;">
                            <!-- Route Info -->
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 15px;">
                                <h4 style="color: #2980b9; margin-top: 0; margin-bottom: 15px; border-left: 4px solid #2980b9; padding-left: 10px;">📋 Route Info</h4>
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px 0; width: 40%;"><strong>From:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.starting_point_id"/></td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px 0;"><strong>To:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.destination_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0;"><strong>Distance:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.distance_km"/> KM</td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Carrier Info -->
                            <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 15px;">
                                <h4 style="color: #2980b9; margin-top: 0; margin-bottom: 15px; border-left: 4px solid #2980b9; padding-left: 10px;">🚚 Carrier Info</h4>
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px 0; width: 40%;"><strong>Driver:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.driver_id"/></td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px 0;"><strong>Phone:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.driver_phone"/></td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid #e0e0e0;">
                                        <td style="padding: 8px 0;"><strong>Vehicle:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.vehicle_id"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 8px 0;"><strong>License Plate:</strong></td>
                                        <td style="padding: 8px 0;"><span t-field="doc.license_plate"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Shipment Info -->
                        <div style="background: #fff3cd; border: 1px solid #ffecb3; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
                            <h4 style="color: #856404; margin-top: 0; margin-bottom: 15px; border-left: 4px solid #ffc107; padding-left: 10px;">📦 Shipment Info</h4>
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="padding: 10px; width: 25%;"><strong>Cargo Type:</strong></td>
                                    <td style="padding: 10px; width: 25%;"><span t-field="doc.cargo_type"/></td>
                                    <td style="padding: 10px; width: 25%;"><strong>Weight:</strong></td>
                                    <td style="padding: 10px; width: 25%;"><span t-field="doc.weight_kg"/> KG</td>
                                </tr>
                                <tr>
                                    <td style="padding: 10px;"><strong>Container No:</strong></td>
                                    <td style="padding: 10px;"><span t-field="doc.container_no"/></td>
                                    <td style="padding: 10px;"><strong>Declaration No:</strong></td>
                                    <td style="padding: 10px;"><span t-field="doc.declaration_no"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Signature & Stamp -->
                        <div style="display: flex; gap: 20px; margin-top: 30px;">
                            <!-- Company Stamp -->
                            <div style="flex: 1; text-align: center; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px;">
                                <p><strong style="color: #2c3e50;">🏢 Company Stamp</strong></p>
                                <div style="min-height: 80px; margin: 10px 0;">
                                    <div style="width: 120px; height: 120px; margin: 0 auto; border: 2px dashed #aaa; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #f8f9fa;">
                                        <span style="color: #999; font-size: 12px;">Stamp Area</span>
                                    </div>
                                </div>
                                <p style="color: #6c757d; font-size: 12px; margin-top: 10px;">______________________</p>
                            </div>
                        </div>

                        <!-- Footer Note -->
                        <div style="margin-top: 30px; text-align: center; font-size: 10px; color: #6c757d; border-top: 1px solid #dee2e6; padding-top: 15px;">
                            <p>This is a computer-generated waybill. No signature is required.</p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>