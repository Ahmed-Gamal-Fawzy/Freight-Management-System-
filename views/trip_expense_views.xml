<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_trip_expense_tree" model="ir.ui.view">
        <field name="name">trip.expense.tree</field>
        <field name="model">trip.expense</field>
        <field name="arch" type="xml">
            <list string="Trip Expenses"
                  create="0"
                  delete="0"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'canceled'"
                  decoration-info="state == 'draft'" >
                <field name="name"/>
                <field name="trip_id"/>
                <field name="driver_id"/>
                <field name="date"/>
                <field name="expense_type"/>
                <field name="amount"/>
                <field name="notes"/>
                <field name="confirmed_by"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-muted="state == 'canceled'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_trip_expense_form" model="ir.ui.view">
        <field name="name">trip.expense.form</field>
        <field name="model">trip.expense</field>
        <field name="arch" type="xml">
            <form string="Trip Expense" create="0" delete="0">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('confirmed','canceled')"/>
                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'canceled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Expense Info">
                            <field name="advance_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="trip_id" readonly="1"/>
                            <field name="driver_id" readonly="1"/>
                            <field name="expense_type"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Financial Info">
                            <field name="date"
                                   readonly="state != 'draft'"/>
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="account_id"
                                   options="{'no_create': True}"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="confirmed_by" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes"
                               nolabel="1"
                               placeholder="Description or notes..."
                               readonly="state != 'draft'"/>
                    </group>
                    <group string="Invoice / Receipt Attachments">
                        <field name="invoice_image"
                               widget="many2many_binary"
                               nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_trip_expense_search" model="ir.ui.view">
        <field name="name">trip.expense.search</field>
        <field name="model">trip.expense</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="driver_id"/>
                <field name="trip_id"/>
                <field name="advance_id"/>
                <separator/>
                <filter string="Confirmed" name="confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter string="Draft"     name="draft"
                        domain="[('state','=','draft')]"/>
                <separator/>
                <filter string="Fuel"          name="fuel"
                        domain="[('expense_type','=','fuel')]"/>
                <filter string="Road Fees"     name="road_fees"
                        domain="[('expense_type','=','road_fees')]"/>
                <separator/>
                <filter string="Driver"       name="group_driver"
                        context="{'group_by': 'driver_id'}"/>
                <filter string="Trip"         name="group_trip"
                        context="{'group_by': 'trip_id'}"/>
                <filter string="Expense Type" name="group_type"
                        context="{'group_by': 'expense_type'}"/>
                <filter string="Month"        name="group_month"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_expense" model="ir.actions.act_window">
        <field name="name">Trip Expenses</field>
        <field name="res_model">trip.expense</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No trip expenses yet. Create one!
            </p>
        </field>
    </record>

</odoo>