<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_freight_trip" model="ir.sequence">
        <field name="name">Freight Trip Sequence</field>
        <field name="code">freight.trip</field>
        <field name="prefix">TRIP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    
    <record id="seq_driver_advance" model="ir.sequence">
        <field name="name">Driver Advance Sequence</field>
        <field name="code">driver.advance</field>
        <field name="prefix">ADV/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_trip_expense" model="ir.sequence">
        <field name="name">Trip Expense</field>
        <field name="code">trip.expense</field>
        <field name="prefix">EXP/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>