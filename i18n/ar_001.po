#. module: freight_management_system
#: model:mail.template,body_html:freight_management_system.email_template_freight_waybill
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>Dear <t t-out=\"object.partner_id.name\"/>,</p>\n"
"                <p>Please find attached the waybill for trip <strong><t t-out=\"object.name\"/></strong>.</p>\n"
"                <p>Route: <t t-out=\"object.starting_point_id.name\"/> → <t t-out=\"object.destination_id.name\"/></p>\n"
"                <p>Best regards,<br/><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p>عزيزي <t t-out=\"object.partner_id.name\"/>,</p>\n"
"                <p>مرفق بوليصة الشحن للرحلة <strong><t t-out=\"object.name\"/></strong>.</p>\n"
"                <p>الطريق: <t t-out=\"object.starting_point_id.name\"/> → <t t-out=\"object.destination_id.name\"/></p>\n"
"                <p>مع أطيب التحيات،<br/><t t-out=\"object.company_id.name\"/></p>\n"
"            </div>\n"
